# ============================================================
# MONA INVEST — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# For Netlify deployment, set these in the Netlify dashboard:
# Site Settings → Environment Variables
# ============================================================

# Supabase (public — safe for frontend)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Anthropic (secret — only used in Netlify Functions, never exposed to frontend)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
# 1. Create a Supabase project at https://supabase.com
# 2. Run supabase-schema.sql in the Supabase SQL Editor
# 3. Copy your Project URL and anon key from Project Settings → API
# 4. Update config.js with your Supabase URL and anon key
# 5. Create an Anthropic account at https://console.anthropic.com
# 6. Generate an API key and add it as ANTHROPIC_API_KEY in Netlify
# 7. Deploy to Netlify by connecting your Git repository
# ============================================================
